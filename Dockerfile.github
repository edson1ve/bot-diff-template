# Trading App — CI/CD Dockerfile (GitHub Actions)
# Build is done separately in CI, output is in build-output/
FROM node:20-alpine AS runner

WORKDIR /app

RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nextjs

COPY build-output/.next/standalone ./
COPY build-output/.next/static ./.next/static
COPY build-output/public ./public

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME=0.0.0.0

USER nextjs

CMD ["node", "server.js"]
